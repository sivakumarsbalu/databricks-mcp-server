# Databricks MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Your Databricks workspace URL
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Authentication Option 1: Personal Access Token (recommended for development)
# Generate at: https://your-workspace.cloud.databricks.com/#setting/account
DATABRICKS_TOKEN=dapi...

# Authentication Option 2: Service Principal (OAuth)
# Use for production or shared environments
# DATABRICKS_CLIENT_ID=your-client-id
# DATABRICKS_CLIENT_SECRET=your-client-secret

# Optional: Default cluster ID for code execution
# If not set, the server will try to find a running cluster
# DATABRICKS_CLUSTER_ID=0123-456789-abcdefgh

# Optional: Default SQL warehouse ID for SQL queries
# If not set, the server will try to find a running warehouse
# DATABRICKS_WAREHOUSE_ID=abcdef1234567890
